{
  "name": "tachyon",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "backend:dev": "conc --names SRV,TSC -c blue,cyan 'bun run backend:serve' 'bun run backend:type-watch'",
    "backend:serve": "bun run --watch apps/backend/src/main.ts",
    "backend:type-watch": "bun --cwd=apps/backend tsc --watch --emitDeclarationOnly --preserveWatchOutput",
    "frontend:dev": "cd apps/frontend && bun run dev",
    "db:generate": "bunx prisma generate && bun --cwd=packages/database tsc",
    "db:push": "bunx prisma db push ",
    "db:seed": "bun run apps/backend/src/seed.ts",
    "db:studio": "bunx prisma studio",
    "backend:lint": "cd apps/backend && eslint",
    "frontend:lint": "cd apps/frontend && eslint"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}